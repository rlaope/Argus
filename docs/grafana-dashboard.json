{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Argus JVM Observability — Virtual Threads, GC, Memory Leak Detection, Allocation Profiling",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "title": "GC Overhead",
      "type": "stat",
      "targets": [{ "expr": "argus_gc_overhead_ratio", "legendFormat": "GC Overhead" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "title": "Heap Used",
      "type": "stat",
      "targets": [{ "expr": "argus_heap_used_bytes", "legendFormat": "Heap Used" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "title": "Active Virtual Threads",
      "type": "stat",
      "targets": [{ "expr": "argus_virtual_threads_active", "legendFormat": "Active VT" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "title": "Leak Suspected",
      "type": "stat",
      "targets": [{ "expr": "argus_gc_leak_suspected", "legendFormat": "Leak" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "KBs" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "title": "Allocation Rate",
      "type": "stat",
      "targets": [{ "expr": "argus_gc_allocation_rate_kbps", "legendFormat": "Alloc Rate" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "title": "Max GC Pause",
      "type": "stat",
      "targets": [{ "expr": "argus_gc_pause_time_max_seconds", "legendFormat": "Max Pause" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "GC & Heap",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Committed" }, "properties": [{ "id": "custom.fillOpacity", "value": 5 }, { "id": "custom.lineStyle", "value": { "fill": "dash" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Heap Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_heap_used_bytes", "legendFormat": "Used" },
        { "expr": "argus_heap_committed_bytes", "legendFormat": "Committed" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Avg" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "GC Pause Times",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_gc_pause_time_max_seconds", "legendFormat": "Max" },
        { "expr": "argus_gc_pause_time_avg_seconds", "legendFormat": "Avg" },
        { "expr": "argus_gc_pause_time_seconds / argus_gc_events", "legendFormat": "Cumulative Avg" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 30 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Overhead" }, "properties": [{ "id": "custom.thresholdsStyle", "value": { "mode": "line" } }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 12,
      "title": "GC Overhead",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_gc_overhead_ratio", "legendFormat": "Overhead" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "KBs", "custom": { "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 13,
      "title": "Allocation & Promotion Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_gc_allocation_rate_kbps", "legendFormat": "Allocation Rate" },
        { "expr": "argus_gc_promotion_rate_kbps", "legendFormat": "Promotion Rate" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.7 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 14,
      "options": { "showThresholdLabels": true, "showThresholdMarkers": true },
      "title": "Memory Leak Confidence (R²)",
      "type": "gauge",
      "targets": [{ "expr": "argus_gc_leak_confidence", "legendFormat": "R²" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Virtual Threads",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "title": "Virtual Thread Lifecycle",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_virtual_threads_active", "legendFormat": "Active" },
        { "expr": "rate(argus_virtual_threads_started_total[1m])", "legendFormat": "Started/min" },
        { "expr": "rate(argus_virtual_threads_ended_total[1m])", "legendFormat": "Ended/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Pinned Events/min" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "title": "Pinning & Carrier Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(argus_virtual_threads_pinned_total[1m])", "legendFormat": "Pinned Events/min" },
        { "expr": "argus_virtual_threads_pinned_unique_stacks", "legendFormat": "Unique Pinning Stacks" },
        { "expr": "argus_carrier_threads_total", "legendFormat": "Carrier Threads" },
        { "expr": "argus_carrier_threads_avg_per_carrier", "legendFormat": "Avg VT/Carrier" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "CPU & Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_cpu_jvm_user_ratio", "legendFormat": "JVM User" },
        { "expr": "argus_cpu_jvm_system_ratio", "legendFormat": "JVM System" },
        { "expr": "argus_cpu_machine_total_ratio", "legendFormat": "Machine Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 31,
      "title": "Metaspace Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_metaspace_used_bytes", "legendFormat": "Used" },
        { "expr": "argus_metaspace_committed_bytes", "legendFormat": "Committed" },
        { "expr": "argus_metaspace_reserved_bytes", "legendFormat": "Reserved" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Allocation & Contention",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 40,
      "title": "Object Allocation",
      "type": "timeseries",
      "targets": [
        { "expr": "argus_allocation_rate_bytes_per_second", "legendFormat": "Allocation Rate (B/s)" },
        { "expr": "rate(argus_allocation_bytes_total[1m])", "legendFormat": "Allocated/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 41,
      "title": "Lock Contention",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(argus_contention_events_total[1m])", "legendFormat": "Contention Events/min" },
        { "expr": "argus_contention_time_seconds", "legendFormat": "Total Contention Time" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["argus", "jvm", "virtual-threads", "gc", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Argus JVM Observability",
  "uid": "argus-jvm-observability",
  "version": 1
}
